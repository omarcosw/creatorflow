# CreatorFlow AI — Environment Variables
# Copy this to .env.production and fill in the values

# REQUIRED — Google Gemini API (AI agents)
GEMINI_API_KEY=

# REQUIRED — App URL
NEXT_PUBLIC_APP_URL=https://creatorflowia.com
NODE_ENV=production

# OPTIONAL — Stripe (payments, needed for paid plans)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_AGENCY=
