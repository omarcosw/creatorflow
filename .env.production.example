# CreatorFlow AI — Environment Variables
# Copy this to .env.production and fill in the values

# REQUIRED — Google Gemini API (AI agents)
GEMINI_API_KEY=

# REQUIRED — App URL
NEXT_PUBLIC_APP_URL=https://creatorflowia.com
NODE_ENV=production

# REQUIRED — Stripe (payments)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (4 plans)
STRIPE_PRICE_SOLO=
STRIPE_PRICE_MAKER=
STRIPE_PRICE_STUDIO=
STRIPE_PRICE_AGENCY=

# OPTIONAL — Stripe Webhook (for subscription management)
STRIPE_WEBHOOK_SECRET=
